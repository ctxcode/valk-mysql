
@ignore_access

test "Multi Statement" {
    let con = connect() ! {
      println(E.message)
      assert(false)
      return
    }
    // Setup table
    let sql = #embed("multi.sql")
    con.query(sql) ! { assert(false) return }

    // Invalid query
    let fail = false
    con.query("INSERX INTO t1 (name) VALUES (\"v1\")") ! {
      fail = true
    }
    assert(fail == true)

    // Add data
    con.query("
    INSERT INTO t1 (name) VALUES (\"v1\");
    INSERT INTO t1 (name) VALUES (\"v2\");
    INSERT INTO t1 (name) VALUES (\"v3\");
    ") ! assert(false)

    // Select
    con.query("SELECT * FROM t1") ! assert(false)
    let r1 = con.fetch_all() ! {
      assert(false)
      return
    }
    assert(r1.length == 3)
    r1.get(0) -> v {
      assert(v.length == 2) // columns
      v.get(0) -> cv : assert(cv == "1")
      v.get(1) -> cv : assert(cv == "v1")
    }
    r1.get(2) -> v {
      assert(v.length == 2) // columns
      v.get(0) -> cv : assert(cv == "3")
      v.get(1) -> cv : assert(cv == "v3")
    }
}
