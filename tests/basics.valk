
test "Query" {
    let con = connect() ! { assert(false) return }
    let name1 = "valk"
    let name2 = "ctx"
    let r : Array[Array[?String]] = .{}

    con.run("TRUNCATE TABLE users") ! { assert(false) return }

    con.bind("name", name1)
    con.run("INSERT INTO users (name) VALUES (:name)") ! { assert(false) return }

    con.bind("name", name1)
    con.run("SELECT * FROM users WHERE name = :name") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 1)

    con.bind("name", name2)
    con.run("SELECT * FROM users WHERE name = :name") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 0)

    con.bind("ids", Array[uint]{ 1, 2, 3 })
    con.run("SELECT * FROM users WHERE id IN (:ids)") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 1)

    // Insert next
    con.bind("name", name2)
    con.run("INSERT INTO users (name) VALUES (:name)") ! { assert(false) return }

    con.bind("ids", Array[uint]{ 1, 2, 3 })
    con.run("SELECT * FROM users WHERE id IN (:ids)") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 2)

}
