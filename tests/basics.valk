
use valk:time

test "Basics" {
    let con = connect() ! {
      println(E.message)
      assert(false)
      return
    }

    let name1 = "valk"
    let name2 = "ctx"
    let r : Array[Map[?String]] = .{}

    // Setup table
    con.query("CREATE TABLE IF NOT EXISTS `users` (
      `id` int NOT NULL AUTO_INCREMENT,
      `name` varchar(50) DEFAULT NULL,
      PRIMARY KEY (`id`)
    )") ! {
      println(E.message)
      assert(false)
      return
    }

    con.query("TRUNCATE TABLE users") ! { assert(false) return }

    //
    let start = time:microtime()
    con.query("INSERT INTO users (name) VALUES (:name)", .{ "name" => name1 }) ! {
      println(E.message)
      assert(false)
      return
    }

    assert(((time:microtime() - start) / 1000) < 40)
    start = time:microtime()

    con.query("SELECT * FROM users WHERE name = :name", .{ "name" => name1 }) ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 1)

    assert(((time:microtime() - start) / 1000) < 10)
    start = time:microtime()

    con.bind("name", name2)
    con.query("SELECT * FROM users WHERE name = :name") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 0)

    assert(((time:microtime() - start) / 1000) < 10)
    start = time:microtime()

    con.bind("ids", Array[uint]{ 1, 2, 3 })
    con.query("SELECT * FROM users WHERE id IN (:ids)") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 1)

    assert(((time:microtime() - start) / 1000) < 10)
    start = time:microtime()

    // Insert next
    con.bind("name", name2)
    con.query("INSERT INTO users (name) VALUES (:name)") ! { assert(false) return }

    assert(((time:microtime() - start) / 1000) < 40)
    start = time:microtime()

    con.bind("ids", Array[uint]{ 1, 2, 3 })
    con.query("SELECT * FROM users WHERE id IN (:ids)") ! { assert(false) return }
    r = con.fetch_all() ! { assert(false) return }
    assert(r.length == 2)

    assert(((time:microtime() - start) / 1000) < 10)
    start = time:microtime()
}
