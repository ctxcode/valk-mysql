
use mysql

test "Query" {
    let con = mysql:connect("127.0.0.1", "test", "root", "valk", 3307) ! {
        println("Connection failed: " + EMSG)
        assert(false)
        return
    }

    con.bindv(1)
    con.run("SELECT * FROM users WHERE id = ?") ! {
        println("Query error: " + EMSG)
        assert(false)
        return
    }

    let row : Array[?String] = .{}
    while con.fetch_row(row) ! { assert(false) return } {
        println(row.join(" | "))
    }
}
