
test "Query" {
    let con = connect() ! { assert(false) return }

    // con.bindv(1)
    // con.bind("ids", Array[uint]{ 1, 2, 3 })
    con.bind("name", "ctx")
    con.run("SELECT * FROM users WHERE name = :name") ! {
        println("Query error: " + EMSG)
        assert(false)
        return
    }

    let r1 = con.fetch_all() ! { assert(false) return }
    assert(r1.length == 1)
}
