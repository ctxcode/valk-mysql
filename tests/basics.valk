
use mysql

test "Query" {
    let con = mysql:connect("127.0.0.1", "test", "root", "valk", 3306) ! {
        println("Connection failed: " + EMSG)
        assert(false)
        return
    }

    con.query("SELECT * FROM users") ! {
        println("Query error: " + EMSG)
        assert(false)
        return
    }
