
use mysql

test "Query" {
    let con = mysql:Connection.new("127.0.0.1", "root", "root", "valk", 3306, null)
    con.connect() ! {
        println("> Connection failed: " + EMSG)
        assert(false)
    }
    assert(true)

    let q = con.query("SELECT * FROM users WHERE id > ?") !!
    q.bindv(10)
    q.select(fn(row: mysql:CurrentRow) {
        println(">>>>>>>>>>>>>>>>>>")
        println("RESULT")
    }) ! {
        println("> Query failed: " + EMSG)
        assert(false)
        return
    }
}
